# ==================== 1. 数据读取与处理 ====================
print("=" * 80)
print("步骤 1: 读取保护区数据并计算相对森林损失率")
print("=" * 80)

# 定义损失年份列（2001-2024）
loss_years = list(range(2001, 2025))
loss_cols = [f'LY_{year}_Area_km2' for year in loss_years]

# 🔧 指定数据类型字典
dtype_dict = {col: float for col in loss_cols}

# 读取数据
print("正在读取Excel文件...")
input_file = r'H:\003 GPA数据\03 按lossyear统计\02GPA_LoseYear\07 绘图（统计图_相对森林损失率）\00 Updated_LossYear_LatLon_2001_2024.xlsx'
df = pd.read_excel(input_file, header=0, dtype=dtype_dict)

print(f"原始数据维度: {df.shape}")
print(f"原始保护区数量: {len(df):,}")

# 🔧 强制转换数据类型
print("\n强制转换数据类型...")
for col in loss_cols:
    if col in df.columns:
        df[col] = pd.to_numeric(df[col], errors='coerce').fillna(0.0).astype(np.float64)

# 转换坐标和面积
df['Longitude'] = pd.to_numeric(df['Longitude'], errors='coerce')
df['Latitude'] = pd.to_numeric(df['Latitude'], errors='coerce')
df['GIS_AREA'] = pd.to_numeric(df['GIS_AREA'], errors='coerce')
df['forestMask_Area_km2'] = pd.to_numeric(df['forestMask_Area_km2'], errors='coerce')

# 🔧 【关键筛选】筛选 forestMask_Area_km2 > 0 的保护区
print("\n" + "="*80)
print("🌲 森林面积筛选")
print("="*80)

if 'forestMask_Area_km2' in df.columns:
    original_count = len(df)
    no_forest_count = (df['forestMask_Area_km2'].fillna(0) == 0).sum()
    
    # 排除森林面积为0的保护区
    df = df[df['forestMask_Area_km2'] > 0].copy()
    
    print(f"原始保护区总数: {original_count:,}")
    print(f"无森林保护区数量: {no_forest_count:,}")
    print(f"排除后保护区数量: {len(df):,}")
else:
    print("\n⚠️ 警告: 数据中没有 'forestMask_Area_km2' 列")

print("="*80)

# 删除坐标缺失的行
df = df.dropna(subset=['Longitude', 'Latitude'])

# 计算总损失
df['Total_Loss_2001_2024'] = df[loss_cols].sum(axis=1)

# 🔧 计算 Relative_Loss_Rate (基于 GIS_AREA)
print("\n计算 Relative_Loss_Rate (基于 GIS_AREA)...")
df['Relative_Loss_Rate'] = 0.0
valid_area_mask = (df['GIS_AREA'] > 0) & (df['GIS_AREA'].notna())
df.loc[valid_area_mask, 'Relative_Loss_Rate'] = (
    df.loc[valid_area_mask, 'Total_Loss_2001_2024'] / df.loc[valid_area_mask, 'GIS_AREA']
) * 100
# 限制最大值为100%
df['Relative_Loss_Rate'] = df['Relative_Loss_Rate'].clip(upper=100.0)

print(f"\nRelative_Loss_Rate 统计:")
print(f"  最小值: {df['Relative_Loss_Rate'].min():.4f}%")
print(f"  最大值: {df['Relative_Loss_Rate'].max():.4f}%")
print(f"  平均值: {df['Relative_Loss_Rate'].mean():.4f}%")


# ==================== 2. 可视化：相对森林损失率空间分布 ====================
print("\n" + "=" * 80)
print("步骤 2: 生成相对森林损失率空间分布图")
print("=" * 80)

# 创建图形
fig_loss = plt.figure(figsize=(5.91, 3.94))
ax_loss = plt.axes(projection=ccrs.PlateCarree())
# ax_loss = plt.axes(projection=ccrs.Robinson())

# 地图特征 (参考 Code 1)
ax_loss.add_feature(cfeature.LAND, facecolor='#FFFFFF', alpha=1.0)
ax_loss.add_feature(cfeature.COASTLINE, linewidth=0.2, edgecolor='#666666')
ax_loss.add_feature(cfeature.BORDERS, linewidth=0.2, edgecolor='#AAAAAA', alpha=0.5)
ax_loss.set_extent([-180, 180, -60, 90], crs=ccrs.PlateCarree())

# 加边框
# ax_loss.spines['geo'].set_visible(False)
ax_loss.spines['geo'].set_visible(True)
ax_loss.spines['geo'].set_edgecolor('#666666')
ax_loss.spines['geo'].set_linewidth(0.25)

# 🔧 配色方案 (参考 Code 1: 浅灰 -> 橙 -> 深红)
# colors_continuous = ['#E8E8E8', '#FFA500', '#FF4500', '#8B0000']
# colors_continuous = ['#F0F0F0', '#90EE90', '#FFD700', '#FF8C00', '#DC143C']
# colors_continuous = ['#F0F0F0', '#90EE90', '#FFD700', '#FFA500', '#FF8C00', '#FF4500', '#8B0000']
# colors_continuous = ['#F0F0F0', '#90EE90', '#FFD700', '#8B0000']   ### 采用
colors_continuous = ['#F0F0F0', "#6BA8E6", "#CEB547", '#8B0000']   ### 1
# colors_continuous = ['#F0F0F0', "#CB78D4", "#7E71E3", "#2BBB40"]   ### 备用
# colors_continuous = ['#F0F0F0', "#8EE7A0", "#CDEB09C4", '#8B0000']
# colors_continuous = ['#E8E8E8', '#FFA500', '#FF4500', '#8B0000']
# colors_continuous = ['#E8E8E8', '#C8E6C9', '#FFA500', '#FF4500', '#8B0000']
# colors_continuous = ['#E8E8E8', '#D3D3D3', '#FFA500', '#FF6347', '#DC143C']
# colors_continuous = ['#F0F0F0', '#E0E0E0', '#FFB84D', '#FF8C42', '#D2691E']
# colors_continuous = ['#EEEEEE', '#FFD580', '#FFA500', '#FF6347']
# 🔧 新的连续配色方案：浅灰色(0) → 绿色 → 橙色 → 深红色
# colors_continuous = ['#E8E8E8', '#90EE90', '#FFA500', '#FF6347', '#DC143C']
# 🔧 最小化红色的配色方案
# colors_continuous = ['#EEEEEE', '#A5D6A7', '#66BB6A', '#FFE57F', '#FFB74D', '#EF5350']  # 10
# # 或者完全去掉红色
# colors_continuous = ['#EEEEEE', '#A5D6A7', '#66BB6A', '#FFD54F', '#FF9800', '#FF6F00']
# # 🔧 优化配色：增加绿色和橙色的占比，减少红色
# colors_continuous = ['#F5F5F5', '#B8E6B8', '#90EE90', '#FFE082', '#FFB84D', '#FF7043']
# colors_continuous = ['#E8E8E8', '#C8E6C9', '#90EE90', '#FFD54F', '#FFA726', '#FF6347']

cmap = LinearSegmentedColormap.from_list('loss_cmap', colors_continuous, N=256)

# 🔧 设置尺寸（根据保护区面积，参考 Code 1）
# 面积单位为 ha, 原 GIS_AREA 为 km2, 需要转换: area_ha = area_km2 * 100
# Code 1 logic: np.sqrt(area_ha/100) * 0.05 => np.sqrt(area_km2) * 0.05
def scale_size(area_km2):
    return np.clip(np.sqrt(area_km2/100) * 0.05, 0.05, 12)

all_data = df.copy()
sizes_all = scale_size(all_data['GIS_AREA'].values)

# 🔧 数据处理：5-95% 分位点 & 0值处理 (参考 Code 1)
rate_values_all = all_data['Relative_Loss_Rate'].values
non_zero_rates = rate_values_all[rate_values_all > 0]

if len(non_zero_rates) > 0:
    vmin_percentile = np.percentile(non_zero_rates, 5)
    vmax_percentile = np.percentile(non_zero_rates, 95)
    
    print(f"\n色度条范围（5-95%分位点）:")
    print(f"  5%分位点 (vmin): {vmin_percentile:.4f}%")
    print(f"  95%分位点 (vmax): {vmax_percentile:.4f}%")
    
    # 将0值设为 vmin 的 1%，使其映射为最浅色
    rates_adjusted = np.where(rate_values_all == 0, vmin_percentile * 0.01, rate_values_all)
    
    # 裁剪异常值
    rates_clipped = np.clip(rates_adjusted, vmin_percentile * 0.01, vmax_percentile)
    
    vmin = vmin_percentile * 0.01
    vmax = vmax_percentile
else:
    vmin, vmax = 0.001, 100.0
    rates_clipped = rate_values_all

# 绘制散点图
scatter = ax_loss.scatter(
    all_data['Longitude'],
    all_data['Latitude'],
    s=sizes_all,
    c=rates_clipped,
    cmap=cmap,
    norm=LogNorm(vmin=vmin, vmax=vmax), # 使用对数标准化以适应偏态分布
    alpha=0.5,
    edgecolors='none',
    transform=ccrs.PlateCarree(),
    zorder=2
)

# 🔧 Colorbar 设置 (参考 Code 1 的位置和样式)
cax = inset_axes(ax_loss,
                 width="20%",
                 height="4%",
                 loc='lower left',
                 bbox_to_anchor=(0.034, 0.10, 1, 1),
                 bbox_transform=ax_loss.transAxes,
                 borderpad=0)

cbar = plt.colorbar(scatter, cax=cax, orientation='horizontal')

cbar.ax.set_title('Loss rate (%)', 
                  fontsize=6, 
                  family='Arial',
                  loc='left',
                  pad=6)

cbar.ax.tick_params(
    labelsize=6,
    size=2,
    width=0.4,
    pad=1,
    direction='out',
    length=5,
    colors='black'
)
cbar.outline.set_linewidth(0.4)

# 🔧 PA Size 图例 (参考 Code 1，对应 GIS_AREA)
# 10^3 ha = 10 km², 10^6 ha = 10,000 km²
example_areas_km2 = [1000, 1000000] 
example_sizes = scale_size(np.array(example_areas_km2))

pa_legend_elements = [
    Line2D([0], [0], marker='o', color='w',
           markerfacecolor='none', markeredgecolor='#999999',
           markeredgewidth=0.5, markersize=example_sizes[0], linestyle='',
           label=r'$10^{3}$'),
    Line2D([0], [0], marker='o', color='w',
           markerfacecolor='none', markeredgecolor='#999999',
           markeredgewidth=0.5, markersize=example_sizes[1], linestyle='',
           label=r'$10^{6}$'),
]

legend_pa = ax_loss.legend(handles=pa_legend_elements,
                           loc='lower left',
                           bbox_to_anchor=(0.020, 0.25),
                           fontsize=6,
                           frameon=False,
                           ncol=2,
                           title='PA size (ha)',
                           title_fontsize=6,
                           columnspacing=0.8,
                           handletextpad=0.1,
                           labelspacing=1.0,
                           alignment='left',
                           prop={'family': 'Arial', 'size': 6})

# 保存图片
output_png = r'H:\003 GPA数据\03 按lossyear统计\02GPA_LoseYear\07 绘图（统计图_相对森林损失率）\02_pk_Relative_Loss_Rate_Style8.png'
plt.tight_layout()
plt.savefig(output_png, dpi=600, bbox_inches='tight')
print(f"\n✓ 相对森林损失率空间分布图已保存: {output_png}")
plt.show()



# ==================== 3. 纬度梯度分析与绘图 ====================
print("\n" + "=" * 80)
print("步骤 3: 统计并绘制随纬度变化的森林损失率曲线")
print("=" * 80)

# 1. 设置纬度区间
lat_step = 1.5  # 纬度步长
lat_bins = np.arange(-60, 90 + lat_step, lat_step)  # 生成纬度区间

# 2. 对纬度进行分箱
df['Lat_Bin'] = pd.cut(df['Latitude'], bins=lat_bins)

# 3. 分组计算平均值和标准差
lat_stats = df.groupby('Lat_Bin')['Relative_Loss_Rate'].agg(['mean', 'std', 'count']).reset_index()

# 4. 获取每个区间的中心纬度
lat_stats['Lat_Center'] = lat_stats['Lat_Bin'].apply(lambda x: x.mid).astype(float)

# 5. 过滤掉数据量过少的区间
min_count = 10
lat_stats_filtered = lat_stats[lat_stats['count'] >= min_count].copy()

print("\n纬度统计结果预览 (前5行):")
print(lat_stats_filtered[['Lat_Center', 'mean', 'std', 'count']].head())

# 画布高度保持 3.94 以匹配地图文件的物理高度
fig_lat, ax_lat = plt.subplots(figsize=(0.8, 3.09))

# 绘制均值曲线
ax_lat.plot(lat_stats_filtered['mean'], lat_stats_filtered['Lat_Center'], 
            color="#8B0000", linewidth=1.0, label='Mean') # 线宽稍微调细一点适配小图

# 绘制标准差范围
ax_lat.fill_betweenx(lat_stats_filtered['Lat_Center'], 
                     lat_stats_filtered['mean'] - lat_stats_filtered['std'], 
                     lat_stats_filtered['mean'] + lat_stats_filtered['std'], 
                     color="#AED0F3",
#                     color="#D9DEE4",
                     alpha=0.8, edgecolor='none')

# 3. 设置 Y 轴 (纬度) - 关键修改
ax_lat.set_ylim(-60, 90)
ax_lat.set_yticks(np.arange(-60, 91, 30))

# 🔧 关键修改 1: 隐藏纵轴(Y)的刻度线和标签
ax_lat.tick_params(axis='y', which='both', left=False, labelleft=False)

ax_lat.set_xlim(-10, 30)

# 🔧 关键修改 2: 隐藏横轴(X)的标签，但保留刻度线
ax_lat.tick_params(axis='x', which='both', 
                   bottom=True,      # 显示刻度线
                   labelbottom=False,# 隐藏数字标签
                   length=2,         # 刻度线长度
                   color='#666666',
                   width=0.25)        # 刻度线宽度

# 移除轴标题
ax_lat.set_ylabel('')
ax_lat.set_title('')
# ax_lat.set_xlabel('Loss Rate (%)', fontsize=6)

for spine in ax_lat.spines.values():
    spine.set_linewidth(0.25)
    spine.set_color('#666666')

# 保存
output_lat_png = r'H:\003 GPA数据\03 按lossyear统计\02GPA_LoseYear\07 绘图（统计图_相对森林损失率）\03_Latitude_Gradient_Curve_Formatted03.png'
plt.savefig(output_lat_png, dpi=600, bbox_inches='tight') # bbox_inches='tight' 会再次自动裁剪白边
print(f"\n✓ 纬度梯度曲线图已保存 (标签已修复): {output_lat_png}")
plt.show()


print("\n" + "="*80)
print("所有分析完成！")
print("="*80)

